<script>
function is_mobile_device(){
	if((window.matchMedia("(max-device-width: 599px)").matches || window.matchMedia("(max-device-height: 599px)").matches) || !window.matchMedia('(hover: hover)').matches){ // mobile
		return true;
	}
	return false;
}
</script>


